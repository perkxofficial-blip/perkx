<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Reset your password</title>
  </head>
  <body style="font-family: Arial, sans-serif; background-color: #f9fafb; padding: 24px;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          <table width="100%" style="max-width: 520px; background: #ffffff; padding: 24px; border-radius: 8px;">
            <tr>
              <td>
                <h2 style="color:#111827;">Reset your password</h2>

                <p>Hi,</p>

                <p>
                  We received a request to reset your password.
                  Click the button below to set a new password:
                </p>

                <p style="text-align:center; margin: 24px 0;">
                  <a
                    href="{{resetPasswordUrl}}"
                    style="
                      display: inline-block;
                      padding: 12px 20px;
                      background: #4f46e5;
                      color: #ffffff;
                      text-decoration: none;
                      border-radius: 6px;
                      font-weight: 600;
                    "
                  >
                    Reset Password
                  </a>
                </p>

                <p>If the button doesn’t work, copy and paste this link into your browser:</p>

                <p style="word-break: break-all; color:#4f46e5;">
                  {{resetPasswordUrl}}
                </p>

                <p style="color:#6b7280;">
                  This link will expire in 15 minutes.
                </p>

                <hr style="margin:24px 0; border:none; border-top:1px solid #e5e7eb;" />

                <p style="font-size: 13px; color:#6b7280;">
                  If you did not request a password reset, you can safely ignore this email.
                </p>

                <p style="margin-top:24px;">
                  Thanks,<br />
                  <strong>PerkX</strong>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
